generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Job {
  id               Int        @id @default(autoincrement())
  createdAt        DateTime   @default(now())
  title            String?
  company          String?
  jdText           String
  rawJdInput       String?
  jdSummary        String?
  jdInsightsJson   String?
  applicationStage String     @default("exploring")
  artifacts        Artifact[]
  notes            JobNote[]
  userId           Int
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Artifact {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  type       String   @default("cover_letter")
  content    String
  jobId      Int
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([createdAt])
}

model CandidateProfile {
  id              Int      @id @default(autoincrement())
  name            String
  headline        String
  summary         String
  skillsJson      String
  voiceGuidelines String
  profileJson     String?
  rawResumeText   String?
  userId          Int      @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Story {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  title     String
  situation String
  action    String
  result    String
  tagsJson  String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id                Int                @id @default(autoincrement())
  email             String             @unique
  passwordHash      String?
  googleSub         String?            @unique
  createdAt         DateTime           @default(now())
  sessions          Session[]
  passwordResetTokens PasswordResetToken[]
  jobs              Job[]
  stories           Story[]
  candidateProfile  CandidateProfile?
}

model Session {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model JobNote {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stage     String
  content   String
  jobId     Int
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([createdAt])
}

model PasswordResetToken {
  id         Int      @id @default(autoincrement())
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
